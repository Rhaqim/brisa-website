{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "nixpacksPlan": {
      "variables": {
        "NIXPACKS_NODE_VERSION": "22"
      }
    }
  },
  "deploy": {
    "startCommand": "HOST=0.0.0.0 node ./dist/server/entry.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
