# PostgreSQL connection string
# For local Docker (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://brisa:brisa_local_pw@localhost:5432/brisa_foundation

# JWT secret — use a long, random string in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Cloudinary — for image hosting
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Create an unsigned upload preset in your Cloudinary dashboard
CLOUDINARY_UPLOAD_PRESET=brisa_uploads
