---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  transparentNav?: boolean;
}

const {
  title,
  description = "Brisa Women's Foundation — Empowering women and children across Africa",
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://brisafoundation.com.ng');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Brisa Women's Foundation</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Brisa Women's Foundation`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@brisawomenfoundation" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/brisalogo.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:opsz,wght@14..32,300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans antialiased text-navy bg-white">
    <slot />
  </body>
</html>
