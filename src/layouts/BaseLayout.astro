---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  transparentNav?: boolean;
}

const {
  title,
  description = "Brisa Women's Foundation empowers women and children across Africa through education, vocational training, and community support.",
  image = '/og-image.jpg',
} = Astro.props;

const siteUrl = 'https://brisafoundation.com.ng';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? siteUrl);
const fullTitle = `${title} | Brisa Women's Foundation`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Brisa Women's Foundation",
  "url": siteUrl,
  "logo": `${siteUrl}/brisalogo.png`,
  "description": "Brisa Women's Foundation empowers women and children across Africa through education, vocational training, and community support.",
  "foundingDate": "2020",
  "areaServed": "Africa",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Support",
    "email": "info@brisafoundation.com.ng"
  },
  "sameAs": [
    "https://www.instagram.com/brisawomensfoundation",
    "https://www.facebook.com/brisawomensfoundation"
  ]
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#3D1035" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Brisa Women's Foundation" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@brisawomenfoundation" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/brisalogo.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:opsz,wght@14..32,300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans antialiased text-navy bg-white">
    <slot />
    <script>
      (() => {
        const threshold = 0.12;
        const rootMargin = '0px 0px -64px 0px';

        function observe(root: Document | Element = document) {
          const els = (root === document ? document : root)
            .querySelectorAll('.reveal:not(.is-visible)');
          if (!els.length) return;
          const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          }, { threshold, rootMargin });
          els.forEach(el => io.observe(el));
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => observe());
        } else {
          observe();
        }

        // Re-run after any dynamic content is added (Svelte client-side hydration)
        new MutationObserver(() => observe()).observe(
          document.body,
          { childList: true, subtree: true }
        );
      })();
    </script>
  </body>
</html>
