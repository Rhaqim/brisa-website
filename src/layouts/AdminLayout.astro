---
import BaseLayout from './BaseLayout.astro';
import AdminSidebar from '../components/admin/AdminSidebar.svelte';

interface Props {
  title: string;
  activeSection?: string;
}

const { title, activeSection = '' } = Astro.props;
const user = Astro.locals.user;
---

<BaseLayout title={`Admin — ${title}`}>
  <div class="min-h-screen bg-warm-50 flex">
    <!-- Sidebar -->
    <AdminSidebar client:load activeSection={activeSection} userEmail={user?.email ?? ''} />

    <!-- Main content -->
    <div class="flex-1 flex flex-col min-w-0 lg:pl-64">
      <!-- Top bar -->
      <header class="sticky top-0 z-30 bg-white border-b border-warm-200 px-6 py-4 flex items-center justify-between">
        <div>
          <h1 class="text-lg font-semibold text-navy">{title}</h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500 hidden sm:block">{user?.email}</span>
          <a
            href="/api/auth/logout"
            class="text-sm text-red-500 hover:text-red-700 font-medium transition-colors"
          >
            Sign out
          </a>
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 p-6 lg:p-8">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
