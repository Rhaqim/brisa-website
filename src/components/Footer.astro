---
import { CONTACT_EMAIL } from '../lib/config';

interface Social {
  facebook?: string;
  twitter?: string;
  instagram?: string;
  youtube?: string;
}

interface Props {
  tagline?: string;
  social?: Social;
  contactEmail?: string;
  contactPhone?: string;
  contactAddress?: string;
  donateUrl?: string;
}

const {
  tagline = "Bringing first-world woman empowerment to local women and children across Africa and beyond.",
  social = {},
  contactEmail = CONTACT_EMAIL,
  contactPhone = '+2348183929999',
  contactAddress = 'Lagos, Nigeria',
  donateUrl = 'https://dashboard.flutterwave.com/donate/obcebpoam3cu',
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-950 border-t border-navy/20">
  <!-- Newsletter -->
  <div class="bg-navy border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex flex-col md:flex-row gap-8 items-center justify-between">
        <div>
          <h3 class="font-serif text-2xl font-bold text-white mb-1">Join Our Mailing List</h3>
          <p class="text-white/50 text-sm">Stay informed about our work and impact across Africa.</p>
        </div>
        <form
          id="newsletter-form"
          class="flex gap-3 w-full md:w-auto"
          novalidate
        >
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 md:w-72 bg-white/10 border border-white/20 text-white placeholder-white/40 rounded-full px-5 py-3 text-sm focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-colors"
          />
          <button
            type="submit"
            class="bg-gold text-navy font-semibold px-6 py-3 rounded-full text-sm hover:bg-gold-400 transition-colors shrink-0"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
        <!-- Brand column -->
        <div class="lg:col-span-2">
          <a href="/" class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-gold flex items-center justify-center text-navy font-serif font-bold text-sm">
              B
            </div>
            <span class="font-serif text-xl font-bold text-white">Brisa Foundation</span>
          </a>
          <p class="text-white/50 text-sm leading-relaxed mb-6 max-w-sm">
            {tagline}
          </p>
          <!-- Social icons -->
          <div class="flex gap-3">
            {social.facebook && (
              <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
                class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-white text-white/60 flex items-center justify-center transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            )}
            {social.twitter && (
              <a href={social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter / X"
                class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-white text-white/60 flex items-center justify-center transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            )}
            {social.instagram && (
              <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-white text-white/60 flex items-center justify-center transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            )}
            {social.youtube && (
              <a href={social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube"
                class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-white text-white/60 flex items-center justify-center transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            )}
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="text-white font-semibold text-sm mb-5">Quick Links</h4>
          <ul class="space-y-3">
            {['About Us', 'Our Works', 'Events', 'Blog', 'Volunteer', 'Contact'].map(link => (
              <li>
                <a
                  href={`/${link.toLowerCase().replace(' ', '-')}`}
                  class="text-white/50 hover:text-gold text-sm transition-colors"
                >
                  {link}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="text-white font-semibold text-sm mb-5">Contact Us</h4>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <span class="text-white/50 text-sm">{contactAddress}</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <a href={`tel:${contactPhone}`} class="text-white/50 hover:text-gold text-sm transition-colors">
                {contactPhone}
              </a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <a href={`mailto:${contactEmail}`} class="text-white/50 hover:text-gold text-sm transition-colors">
                {contactEmail}
              </a>
            </li>
          </ul>

          <a
            href={donateUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 bg-gold text-navy font-semibold text-sm px-5 py-2.5 rounded-full hover:bg-gold-400 transition-colors"
          >
            Donate Now
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 px-4 sm:px-6 lg:px-8 py-5">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-white/30 text-xs">
        <p>© {currentYear} Brisa Women's Foundation. All rights reserved.</p>
        <p>
          Designed with ♥ for African women everywhere
        </p>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(e.target as HTMLFormElement).get('email');
    if (!email) return;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Subscribing…';
    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        btn.textContent = '✓ Subscribed!';
        btn.classList.add('opacity-70');
        (form.querySelector('input') as HTMLInputElement).value = '';
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
    }
  });
</script>
