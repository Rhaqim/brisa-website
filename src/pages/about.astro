---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.svelte';
import { getSettings } from '../lib/settings';

const s = await getSettings();
---

<Layout title="About Us | Brisa Women's Foundation" description="Brisa Women's Foundation is a Nigerian non-profit committed to empowering vulnerable women, widows, and single mothers through skills training, financial support, and community-based programmes.">
  <!-- Page Hero -->
  <section class="pt-36 pb-20 bg-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url('{s.hero_image_url}'); background-size: cover; background-position: center;"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy/90 to-navy"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal reveal-up">
      <p class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-0.5 bg-gold"></span>
        About Us
        <span class="w-6 h-0.5 bg-gold"></span>
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        {s.about_hero_title || 'Driven by Purpose, Guided by Compassion'}
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        {s.about_hero_body || 'We believe every woman deserves the opportunity to reach her full potential.'}
      </p>
    </div>
  </section>

  <!-- Story section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal reveal-left">
          <p class="section-tag">Our Story</p>
          <h2 class="font-serif text-4xl font-bold text-navy mb-6 leading-tight">
            Born from lived experience. Built to create lasting change.
          </h2>
          <div class="w-12 h-1 bg-gold mb-8 rounded-full"></div>
          <div class="prose prose-lg text-gray-600 space-y-4">
            <p>
              Brisa Women Foundation is a registered non-profit organisation committed to empowering vulnerable women and young ladies through sustainable initiatives that restore dignity, create opportunities, and promote long-term economic independence.
            </p>
            <p>
              Founded in 2015 by Amb. Delphine Oyinye Nwachukwu, the foundation was born out of lived experience, resilience, and a deep understanding of the realities faced by widows, single mothers, and low-income women across Nigeria. What began as a personal journey of survival and determination has grown into a movement dedicated to helping women rebuild their lives and support their families with confidence and dignity.
            </p>
            <p>
              Over the years, the foundation has empowered more than 1,500 women through skills acquisition programmes and provided financial grants and aid to over 4,800 women across different communities — spanning Lagos State, Imo State, and other parts of Nigeria through both physical and virtual outreach.
            </p>
            <p>
              Our work is especially focused on reaching women affected by poverty, unemployment, displacement, and social exclusion, including communities in the South-East region impacted by insecurity and economic disruption.
            </p>
          </div>
        </div>
        <div class="relative reveal reveal-right">
          {s.mission_image_url && (
            <img
              src={s.mission_image_url}
              alt="Brisa Women's Foundation in action"
              class="rounded-2xl w-full object-cover aspect-[4/5] shadow-xl"
              loading="lazy"
            />
          )}
          <div class="absolute -bottom-4 -left-4 bg-forest text-white rounded-2xl px-6 py-4 shadow-xl">
            <div class="font-serif text-3xl font-bold text-gold">Since 2015</div>
            <div class="text-xs text-white/70 mt-0.5">Making a difference in Nigeria</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { number: s.stat_1_number || '500+', label: s.stat_1_label || 'Women Empowered' },
          { number: s.stat_2_number || '50+', label: s.stat_2_label || 'Communities Reached' },
          { number: s.stat_3_number || '200+', label: s.stat_3_label || 'Scholarships Granted' },
          { number: s.stat_4_number || '12+', label: s.stat_4_label || 'Years of Impact' },
        ].map((stat, i) => (
          <div class="text-center reveal reveal-scale" style={`transition-delay: ${i * 120}ms`}>
            <div class="font-serif text-5xl font-bold text-navy mb-2">{stat.number}</div>
            <div class="text-sm text-gray-500 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values / Pillars -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16 reveal reveal-up">
        <p class="section-tag">Our Values</p>
        <h2 class="font-serif text-4xl font-bold text-navy leading-tight">
          What guides everything we do
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: 'Dignity', body: 'We approach every woman and child with deep respect, honouring their inherent worth and the unique circumstances of their journey. Empowerment must never feel like charity.' },
          { title: 'Community', body: 'We believe change is most powerful when it comes from within. We work alongside communities, not above them, building partnerships rooted in trust and mutual respect.' },
          { title: 'Sustainability', body: 'We invest in skills, entrepreneurship, and systems that create self-sustaining change — so every woman we reach can stand firmly on her own and lift others in turn.' },
        ].map((v, i) => (
          <div class="bg-warm-50 rounded-2xl p-8 border border-warm-200 reveal reveal-up" style={`transition-delay: ${i * 160}ms`}>
            <div class="w-10 h-10 bg-gold/20 rounded-xl flex items-center justify-center mb-5">
              <div class="w-3 h-3 rounded-full bg-gold"></div>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">{v.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    client:visible
    title={s.cta_title}
    body={s.cta_body}
    donateUrl={s.donate_url}
  />
</Layout>
