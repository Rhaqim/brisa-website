---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.svelte';
import GallerySection from '../components/GallerySection.svelte';
import ImpactStory from '../components/ImpactStory.svelte';
import { getSettings } from '../lib/settings';
import { sql } from '../lib/db';

const s = await getSettings();

const galleryImages = await sql`
  SELECT id, url, alt_text, caption FROM gallery_images ORDER BY sort_order ASC
`;

const stories = await sql`
  SELECT name, story, location, image_url
  FROM impact_stories
  WHERE is_featured = TRUE
  ORDER BY sort_order ASC
`;
---

<Layout title="Our Works" description="See the impact Brisa Women's Foundation is making across communities in Nigeria and Africa.">
  <!-- Hero -->
  <section class="pt-36 pb-20 bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-dark to-navy opacity-90"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center reveal reveal-up">
      <p class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-0.5 bg-gold"></span>
        Our Works
        <span class="w-6 h-0.5 bg-gold"></span>
      </p>
      <h1 class="font-serif text-5xl lg:text-6xl font-bold text-white mb-4">Making a Difference</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        From Lagos to rural communities across Nigeria, our programmes are creating lasting, self-sustaining change.
      </p>
    </div>
  </section>

  <!-- Programme areas -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16 reveal reveal-up">
        <p class="section-tag">Our Programmes</p>
        <h2 class="font-serif text-4xl font-bold text-navy leading-tight">
          How we create change
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            title: 'Educational Scholarships',
            body: 'We provide scholarships for less privileged children, ensuring that poverty does not determine a child\'s future. Each scholarship covers tuition, materials, and where needed, feeding and accommodation.',
            icon: '🎓',
          },
          {
            title: 'Vocational Training',
            body: 'Skills acquisition programmes equip women with practical, market-relevant skills: tailoring, baking, digital literacy, and entrepreneurship, giving them the tools to generate their own income.',
            icon: '🛠️',
          },
          {
            title: 'Grant & Microloan Programme',
            body: 'We provide grants and microloans to women with viable business ideas or existing micro-enterprises, enabling them to grow and become economically independent.',
            icon: '💰',
          },
          {
            title: 'Parenting Workshops',
            body: 'Our parenting seminars equip parents with knowledge, confidence, and practical skills to raise healthy, well-adjusted children even in challenging circumstances.',
            icon: '👨‍👩‍👧',
          },
          {
            title: 'Elderly & Orphan Support',
            body: 'We support aged people and contribute to orphanages and motherless baby homes, ensuring the most vulnerable members of our communities are not left behind.',
            icon: '🤝',
          },
          {
            title: 'Career Development',
            body: 'Through career talks and mentorship sessions, we connect women and young people with professionals and opportunities, helping them envision and pursue ambitious futures.',
            icon: '📈',
          },
        ].map((prog, i) => (
          <div class="flex gap-5 p-7 rounded-2xl border border-warm-200 bg-warm-50 hover:shadow-md transition-shadow reveal reveal-up" style={`transition-delay: ${i * 100}ms`}>
            <div class="text-3xl shrink-0">{prog.icon}</div>
            <div>
              <h3 class="font-serif text-xl font-bold text-navy mb-2">{prog.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{prog.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <GallerySection client:visible images={galleryImages as any} />

  <!-- Stories -->
  {(stories as any[]).map(story => (
    <ImpactStory client:visible story={story} />
  ))}

  <CTASection
    client:visible
    title={s.cta_title}
    body={s.cta_body}
    donateUrl={s.donate_url}
  />
</Layout>
