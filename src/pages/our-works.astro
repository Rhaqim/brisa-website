---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.svelte';
import GalleryAlbums from '../components/GalleryAlbums.svelte';
import ImpactStory from '../components/ImpactStory.svelte';
import { getSettings } from '../lib/settings';
import { sql, DB_CONNECTED } from '../lib/db';
import { FALLBACK_STORIES } from '../lib/fallback';
import { readStaticGallery } from '../lib/staticGallery';

const s = await getSettings();

let galleryImages: any[] = [];
try {
  galleryImages = DB_CONNECTED
    ? await sql`SELECT id, url, alt_text, caption, category FROM gallery_images ORDER BY sort_order ASC`
    : readStaticGallery();
} catch { galleryImages = readStaticGallery(); }

let stories: typeof FALLBACK_STORIES = [];
try {
  stories = DB_CONNECTED
    ? await sql`
        SELECT name, story, location, image_url
        FROM impact_stories
        WHERE is_featured = TRUE
        ORDER BY sort_order ASC
      `
    : FALLBACK_STORIES;
} catch { stories = FALLBACK_STORIES; }
---

<Layout title="Our Works" description="See the impact Brisa Women's Foundation is making across communities in Nigeria and Africa.">
  <!-- Hero -->
  <section class="pt-36 pb-20 bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-dark to-navy opacity-90"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center reveal reveal-up">
      <p class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-0.5 bg-gold"></span>
        Our Works
        <span class="w-6 h-0.5 bg-gold"></span>
      </p>
      <h1 class="font-serif text-5xl lg:text-6xl font-bold text-white mb-4">Making a Difference</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Serving vulnerable women, widows, and single mothers across urban and rural communities in Nigeria.
      </p>
    </div>
  </section>

  <!-- Programme areas -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16 reveal reveal-up">
        <p class="section-tag">Our Programmes</p>
        <h2 class="font-serif text-4xl font-bold text-navy leading-tight">
          How we create change
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            title: 'Financial Empowerment',
            body: 'We provide grants and microloans to women entrepreneurs, supporting business start-ups and expansions. Our financial support programmes help women achieve economic independence and build sustainable livelihoods for their families.',
            icon: '💰',
          },
          {
            title: 'Entrepreneurship Development',
            body: 'Business training and capacity-building programmes equip women with the knowledge to run successful enterprises. Mentorship from experienced professionals and access to networks and market opportunities help them grow confidently.',
            icon: '🚀',
          },
          {
            title: 'Healthcare & Wellness',
            body: 'Health awareness campaigns and wellness outreach programmes ensure women and their communities have access to the care and knowledge they need to thrive — covering physical health, mental wellness, and preventive care.',
            icon: '🏥',
          },
          {
            title: 'Skill Acquisition & Livelihood',
            body: 'Vocational training programmes equip women with practical, income-generating skills including tailoring, baking, digital literacy, and entrepreneurship — creating clear pathways to self-reliance and economic dignity.',
            icon: '🛠️',
          },
          {
            title: 'Education & Family Support',
            body: 'We support vulnerable children and young girls through scholarship opportunities and back-to-school interventions. Parental empowerment programmes strengthen families, giving parents the tools to raise confident, well-supported children.',
            icon: '📚',
          },
          {
            title: 'Food, Medicine & Relief',
            body: 'For women and families facing acute hardship, we provide food and medicine interventions and crisis support — ensuring that no woman is left without help in her most vulnerable moments.',
            icon: '🤝',
          },
        ].map((prog, i) => (
          <div class="flex gap-5 p-7 rounded-2xl border border-warm-200 bg-warm-50 hover:shadow-md transition-shadow reveal reveal-up" style={`transition-delay: ${i * 100}ms`}>
            <div class="text-3xl shrink-0">{prog.icon}</div>
            <div>
              <h3 class="font-serif text-xl font-bold text-navy mb-2">{prog.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{prog.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery with album tabs -->
  <GalleryAlbums client:visible images={galleryImages as any[]} showAlbumTabs={true} />

  <!-- Stories -->
  {(stories as any[]).map(story => (
    <ImpactStory client:visible story={story} />
  ))}

  <CTASection
    client:visible
    title={s.cta_title}
    body={s.cta_body}
    donateUrl={s.donate_url}
  />
</Layout>
