---
import Layout from '../layouts/Layout.astro';
import { getSettings } from '../lib/settings';
import { CONTACT_EMAIL } from '../lib/config';
import ContactForm from '../components/ContactForm.svelte';

const s = await getSettings();
---

<Layout title="Contact" description="Get in touch with Brisa Women's Foundation. We'd love to hear from you.">
  <!-- Hero -->
  <section class="pt-36 pb-20 bg-navy relative overflow-hidden">
    <div class="relative max-w-4xl mx-auto px-4 text-center reveal reveal-up">
      <p class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-0.5 bg-gold"></span>
        Contact Us
        <span class="w-6 h-0.5 bg-gold"></span>
      </p>
      <h1 class="font-serif text-5xl lg:text-6xl font-bold text-white mb-4">Get In Touch</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Have a question, a partnership idea, or just want to say hello? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Info side -->
        <div>
          <p class="section-tag">Reach Us</p>
          <h2 class="font-serif text-3xl font-bold text-navy mb-8">We're always open to conversations</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-navy mb-0.5">Our Location</div>
                <div class="text-gray-600 text-sm">{s.contact_address || 'Lagos, Nigeria'}</div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-navy mb-0.5">Phone</div>
                <a href={`tel:${s.contact_phone}`} class="text-gray-600 text-sm hover:text-gold transition-colors">
                  {s.contact_phone || '+2348183929999'}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-navy mb-0.5">Email</div>
                <a href={`mailto:${s.contact_email}`} class="text-gray-600 text-sm hover:text-gold transition-colors">
                  {s.contact_email || CONTACT_EMAIL}
                </a>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div class="mt-10 pt-8 border-t border-warm-200">
            <p class="text-sm font-semibold text-navy mb-4">Follow Our Journey</p>
            <div class="flex gap-3">
              {s.social_facebook && (
                <a href={s.social_facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
                  class="w-10 h-10 rounded-full bg-navy text-white hover:bg-gold hover:text-white flex items-center justify-center transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {s.social_instagram && (
                <a href={s.social_instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                  class="w-10 h-10 rounded-full bg-navy text-white hover:bg-gold hover:text-white flex items-center justify-center transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              )}
              {s.social_youtube && (
                <a href={s.social_youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube"
                  class="w-10 h-10 rounded-full bg-navy text-white hover:bg-gold hover:text-white flex items-center justify-center transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Form side -->
        <div class="bg-white rounded-2xl border border-warm-200 shadow-sm p-8">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</Layout>
