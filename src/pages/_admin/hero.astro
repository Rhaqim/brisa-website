---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ImageUpload from '../../components/admin/ImageUpload.svelte';
import { getSettings, setSettings } from '../../lib/settings';
import { getUploadConfig } from '../../lib/cloudinary';

let saved = false;
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  try {
    await setSettings({
      hero_title: String(form.get('hero_title') ?? ''),
      hero_subtitle: String(form.get('hero_subtitle') ?? ''),
      hero_image_url: String(form.get('hero_image_url') ?? ''),
      hero_cta_text: String(form.get('hero_cta_text') ?? ''),
      hero_cta_url: String(form.get('hero_cta_url') ?? ''),
      hero_secondary_cta_text: String(form.get('hero_secondary_cta_text') ?? ''),
      hero_secondary_cta_url: String(form.get('hero_secondary_cta_url') ?? ''),
      stat_1_number: String(form.get('stat_1_number') ?? ''),
      stat_1_label: String(form.get('stat_1_label') ?? ''),
      stat_2_number: String(form.get('stat_2_number') ?? ''),
      stat_2_label: String(form.get('stat_2_label') ?? ''),
      stat_3_number: String(form.get('stat_3_number') ?? ''),
      stat_3_label: String(form.get('stat_3_label') ?? ''),
      stat_4_number: String(form.get('stat_4_number') ?? ''),
      stat_4_label: String(form.get('stat_4_label') ?? ''),
    });
    saved = true;
  } catch (e) {
    error = 'Failed to save. Please try again.';
  }
}

const s = await getSettings();
const uploadConfig = getUploadConfig();
---

<AdminLayout title="Hero Section" activeSection="hero">
  {saved && (
    <div class="mb-6 bg-forest/10 border border-forest/20 text-forest text-sm px-4 py-3 rounded-lg flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
      Changes saved successfully.
    </div>
  )}
  {error && (
    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg">{error}</div>
  )}

  <form method="POST" class="space-y-8">
    <!-- Hero Image -->
    <div class="admin-card p-6">
      <h3 class="font-semibold text-navy mb-5">Hero Image</h3>

      <!-- Image upload (Svelte, uploads to Cloudinary then fills hidden input) -->
      <ImageUpload
        client:load
        cloudName={uploadConfig.cloudName}
        uploadPreset={uploadConfig.uploadPreset}
        currentUrl={s.hero_image_url}
        label="Background Image (recommended: 2000×1200px)"
        targetInputId="hero_image_url_input"
      />
      <input type="hidden" name="hero_image_url" id="hero_image_url_input" value={s.hero_image_url} />

      <p class="mt-2 text-xs text-gray-400">Or paste a direct URL below:</p>
      <input
        type="url"
        name="hero_image_url"
        value={s.hero_image_url}
        class="input-field mt-1"
        placeholder="https://..."
        id="hero_image_url_text"
      />
    </div>

    <!-- Hero Text -->
    <div class="admin-card p-6">
      <h3 class="font-semibold text-navy mb-5">Hero Text</h3>
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-navy mb-1.5">Headline</label>
          <input type="text" name="hero_title" value={s.hero_title} class="input-field" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-navy mb-1.5">Sub-headline</label>
          <textarea name="hero_subtitle" rows="3" class="input-field resize-none">{s.hero_subtitle}</textarea>
        </div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="admin-card p-6">
      <h3 class="font-semibold text-navy mb-5">Call-to-Action Buttons</h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-3">
          <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Primary CTA</h4>
          <div>
            <label class="block text-xs font-medium text-navy mb-1">Button Label</label>
            <input type="text" name="hero_cta_text" value={s.hero_cta_text} class="input-field" />
          </div>
          <div>
            <label class="block text-xs font-medium text-navy mb-1">Button URL</label>
            <input type="text" name="hero_cta_url" value={s.hero_cta_url} class="input-field" />
          </div>
        </div>
        <div class="space-y-3">
          <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Secondary CTA</h4>
          <div>
            <label class="block text-xs font-medium text-navy mb-1">Button Label</label>
            <input type="text" name="hero_secondary_cta_text" value={s.hero_secondary_cta_text} class="input-field" />
          </div>
          <div>
            <label class="block text-xs font-medium text-navy mb-1">Button URL</label>
            <input type="text" name="hero_secondary_cta_url" value={s.hero_secondary_cta_url} class="input-field" />
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="admin-card p-6">
      <h3 class="font-semibold text-navy mb-5">Impact Statistics (displayed on hero bar)</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[1, 2, 3, 4].map(i => (
          <div class="space-y-2">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">Stat {i}</label>
            <input type="text" name={`stat_${i}_number`} value={s[`stat_${i}_number`]} class="input-field" placeholder="500+" />
            <input type="text" name={`stat_${i}_label`} value={s[`stat_${i}_label`]} class="input-field" placeholder="Women Empowered" />
          </div>
        ))}
      </div>
    </div>

    <div class="flex justify-end">
      <button type="submit" class="btn-primary px-10">Save Changes</button>
    </div>
  </form>
</AdminLayout>

<script>
  // Sync the URL text input to the hidden input so only one value is submitted
  const textInput = document.getElementById('hero_image_url_text') as HTMLInputElement;
  const hiddenInput = document.getElementById('hero_image_url_input') as HTMLInputElement;
  textInput?.addEventListener('input', () => {
    if (hiddenInput) hiddenInput.value = textInput.value;
  });
</script>
