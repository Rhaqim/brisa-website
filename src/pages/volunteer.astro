---
import Layout from '../layouts/Layout.astro';
import { getSettings } from '../lib/settings';
import CTASection from '../components/CTASection.svelte';

const s = await getSettings();

let submitted = false;
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const name = String(form.get('name') ?? '').trim();
  const email = String(form.get('email') ?? '').trim();
  const interest = String(form.get('interest') ?? '').trim();
  const message = String(form.get('message') ?? '').trim();

  if (!name || !email || !interest) {
    error = 'Please fill in all required fields.';
  } else {
    // TODO: send notification email
    submitted = true;
  }
}
---

<Layout title="Volunteer — Brisa Women's Foundation">
  <!-- Hero -->
  <section class="bg-navy pt-36 pb-20 px-6 text-white text-center">
    <div class="container-narrow mx-auto">
      <span class="section-tag mb-6">Join the Movement</span>
      <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6">
        Volunteer With Us
      </h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        Your time, skills, and energy can change lives. Join a community of
        change-makers dedicated to empowering women and children across Africa.
      </p>
    </div>
  </section>

  <!-- Why volunteer -->
  <section class="py-20 bg-warm-50">
    <div class="container-wide mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: '🤝', title: 'Make a Real Difference', desc: 'Work directly with communities, seeing tangible impact every day.' },
          { icon: '🌍', title: 'Build Global Connections', desc: 'Join a network of passionate advocates from across the world.' },
          { icon: '📈', title: 'Grow Your Skills', desc: 'Develop leadership, communication, and project management abilities.' },
        ].map(item => (
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm border border-warm-100">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="font-serif text-xl text-navy mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas of volunteering -->
  <section class="py-20">
    <div class="container-wide mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-tag mb-4">Opportunities</span>
        <h2 class="font-serif text-3xl md:text-5xl text-navy">How You Can Help</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { role: 'Community Outreach', desc: 'Connect with women in underserved areas, facilitate workshops and awareness campaigns.', time: '4–8 hrs/week' },
          { role: 'Mentorship', desc: 'Guide young women in career, education, and personal development journeys.', time: '2–4 hrs/week' },
          { role: 'Skills Trainer', desc: 'Share your professional skills — digital literacy, finance, entrepreneurship.', time: 'Flexible' },
          { role: 'Events Support', desc: 'Help plan and run our conferences, fundraisers, and community events.', time: 'As needed' },
          { role: 'Content & Media', desc: 'Write, photograph, or film our stories to amplify our impact globally.', time: 'Flexible' },
          { role: 'Administrative Support', desc: 'Keep our operations running smoothly with data, coordination, and research.', time: '3–5 hrs/week' },
        ].map(item => (
          <div class="border border-warm-200 rounded-2xl p-6 hover:border-gold/50 hover:shadow-md transition-all">
            <h3 class="font-semibold text-navy text-lg mb-2">{item.role}</h3>
            <p class="text-gray-600 text-sm mb-4 leading-relaxed">{item.desc}</p>
            <span class="text-xs font-semibold text-forest bg-forest/10 px-3 py-1 rounded-full">{item.time}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application form -->
  <section class="py-20 bg-warm-50">
    <div class="container-narrow mx-auto px-6">
      <div class="text-center mb-12">
        <span class="section-tag mb-4">Apply</span>
        <h2 class="font-serif text-3xl md:text-4xl text-navy">Ready to Join?</h2>
        <p class="text-gray-600 mt-3">Fill in your details and we'll be in touch within 3 business days.</p>
      </div>

      {submitted ? (
        <div class="bg-forest/10 border border-forest/30 text-forest rounded-2xl p-10 text-center">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="font-serif text-2xl mb-2">Thank You!</h3>
          <p class="text-sm">We've received your application and will contact you shortly.</p>
        </div>
      ) : (
        <form method="POST" class="bg-white rounded-2xl p-8 shadow-sm border border-warm-100 space-y-6">
          {error && <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg">{error}</div>}
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-navy mb-1.5">Full Name *</label>
              <input type="text" name="name" required class="input-field" />
            </div>
            <div>
              <label class="block text-sm font-medium text-navy mb-1.5">Email *</label>
              <input type="email" name="email" required class="input-field" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Area of Interest *</label>
            <select name="interest" required class="input-field">
              <option value="">Select one…</option>
              <option>Community Outreach</option>
              <option>Mentorship</option>
              <option>Skills Trainer</option>
              <option>Events Support</option>
              <option>Content & Media</option>
              <option>Administrative Support</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Why do you want to volunteer?</label>
            <textarea name="message" rows="4" class="input-field resize-none" placeholder="Tell us a little about yourself and your motivation…"></textarea>
          </div>
          <button type="submit" class="w-full btn-primary py-4 text-base">Submit Application</button>
        </form>
      )}
    </div>
  </section>

  <CTASection
    client:visible
    title={s.cta_title ?? 'Together We Can Do More'}
    body={s.cta_body ?? ''}
    donateUrl={s.donate_url ?? '#'}
  />
</Layout>
