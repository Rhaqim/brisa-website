---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.svelte';
import { getSettings } from '../lib/settings';
import { sql, DB_CONNECTED } from '../lib/db';
import { FALLBACK_EVENTS } from '../lib/fallback';

const s = await getSettings();

let events: typeof FALLBACK_EVENTS = [];
try {
  events = DB_CONNECTED
    ? await sql`
        SELECT id, title, description, date, end_date, location, image_url, registration_url, status, is_featured
        FROM events
        ORDER BY
          CASE status
            WHEN 'upcoming' THEN 1
            WHEN 'ongoing' THEN 2
            ELSE 3
          END,
          date ASC
      `
    : FALLBACK_EVENTS;
} catch { events = FALLBACK_EVENTS; }

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function formatMonth(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { month: 'short' }).toUpperCase();
}

function formatDay(dateStr: string) {
  return new Date(dateStr).getDate();
}
---

<Layout title="Events" description="Upcoming and past events from Brisa Women's Foundation: workshops, seminars, and community programmes.">
  <!-- Page Hero -->
  <section class="pt-36 pb-20 bg-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url('{s.hero_image_url}'); background-size: cover;"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center reveal reveal-up">
      <p class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-0.5 bg-gold"></span>
        Events
        <span class="w-6 h-0.5 bg-gold"></span>
      </p>
      <h1 class="font-serif text-5xl lg:text-6xl font-bold text-white mb-4">Our Events</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Join us at our workshops, seminars, and community programmes as we work to empower women across Africa.
      </p>
    </div>
  </section>

  <!-- Events list -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {events.length > 0 ? (
        <div class="space-y-6">
          {(events as any[]).map(event => (
            <article class="bg-white rounded-2xl border border-warm-200 shadow-sm overflow-hidden flex flex-col md:flex-row hover:shadow-md transition-shadow">
              {event.image_url ? (
                <div class="md:w-64 shrink-0">
                  <img
                    src={event.image_url}
                    alt={event.title}
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="md:w-64 shrink-0 bg-gradient-to-br from-navy to-forest hidden md:flex items-center justify-center">
                  <svg class="w-16 h-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
                  </svg>
                </div>
              )}
              <div class="p-6 md:p-8 flex-1 flex flex-col">
                <!-- Status badge -->
                <div class="flex items-center gap-3 mb-4">
                  <span class={`text-xs font-semibold px-3 py-1 rounded-full ${
                    event.status === 'upcoming' ? 'bg-forest/10 text-forest' :
                    event.status === 'ongoing' ? 'bg-gold/20 text-gold-700' :
                    'bg-gray-100 text-gray-500'
                  }`}>
                    {event.status.charAt(0).toUpperCase() + event.status.slice(1)}
                  </span>
                  {event.is_featured && (
                    <span class="text-xs font-semibold px-3 py-1 rounded-full bg-navy/10 text-navy">
                      Featured
                    </span>
                  )}
                </div>

                <h2 class="font-serif text-2xl font-bold text-navy mb-3">{event.title}</h2>

                {event.description && (
                  <p class="text-gray-600 text-sm leading-relaxed mb-5 line-clamp-3 flex-1">
                    {event.description}
                  </p>
                )}

                <div class="flex flex-wrap gap-4 text-sm text-gray-500 mt-auto pt-4 border-t border-warm-100">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
                    </svg>
                    {formatDate(event.date)}
                  </div>
                  {event.location && (
                    <div class="flex items-center gap-1.5">
                      <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                      </svg>
                      {event.location}
                    </div>
                  )}
                  {event.registration_url && event.status === 'upcoming' && (
                    <a
                      href={event.registration_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="ml-auto inline-flex items-center gap-1.5 text-forest font-semibold hover:underline"
                    >
                      Register
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-32 text-gray-400">
          <svg class="w-20 h-20 mx-auto mb-6 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
          </svg>
          <h3 class="font-serif text-2xl font-bold text-navy/40 mb-2">No events yet</h3>
          <p>Check back soon for upcoming programmes and workshops.</p>
        </div>
      )}
    </div>
  </section>

  <CTASection
    client:visible
    title={s.cta_title}
    body={s.cta_body}
    donateUrl={s.donate_url}
  />
</Layout>
