---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { sql } from '../../lib/db';

const url = new URL(Astro.request.url);
const showNew = url.searchParams.get('new') === '1';
const editId = url.searchParams.get('edit');

let saved = false;
let deleted = false;
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');

  try {
    if (action === 'delete') {
      const id = String(form.get('id'));
      await sql`DELETE FROM events WHERE id = ${id}`;
      deleted = true;
    } else if (action === 'upsert') {
      const id = form.get('id') ? String(form.get('id')) : null;
      const title = String(form.get('title') ?? '').trim();
      const description = String(form.get('description') ?? '').trim();
      const date = String(form.get('date') ?? '');
      const location = String(form.get('location') ?? '').trim();
      const image_url = String(form.get('image_url') ?? '').trim();
      const registration_url = String(form.get('registration_url') ?? '').trim();
      const status = String(form.get('status') ?? 'upcoming');
      const is_featured = form.get('is_featured') === 'on';

      if (!title || !date) {
        error = 'Title and date are required.';
      } else if (id) {
        await sql`
          UPDATE events SET
            title = ${title}, description = ${description}, date = ${date},
            location = ${location}, image_url = ${image_url || null},
            registration_url = ${registration_url || null},
            status = ${status}, is_featured = ${is_featured},
            updated_at = NOW()
          WHERE id = ${id}
        `;
        saved = true;
      } else {
        await sql`
          INSERT INTO events (title, description, date, location, image_url, registration_url, status, is_featured)
          VALUES (${title}, ${description}, ${date}, ${location}, ${image_url || null}, ${registration_url || null}, ${status}, ${is_featured})
        `;
        saved = true;
        return Astro.redirect('/admin/events');
      }
    }
  } catch (e) {
    error = 'Something went wrong. Please try again.';
  }
}

const events = await sql`
  SELECT id, title, date, location, status, is_featured
  FROM events
  ORDER BY date DESC
`;

let editEvent: any = null;
if (editId) {
  [editEvent] = await sql`SELECT * FROM events WHERE id = ${editId}`;
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric'
  });
}

function toDatetimeLocal(dateStr: string) {
  return new Date(dateStr).toISOString().slice(0, 16);
}
---

<AdminLayout title="Events" activeSection="events">
  {saved && (
    <div class="mb-6 bg-forest/10 border border-forest/20 text-forest text-sm px-4 py-3 rounded-lg">✓ Event saved.</div>
  )}
  {deleted && (
    <div class="mb-6 bg-gold/10 border border-gold/20 text-gold-700 text-sm px-4 py-3 rounded-lg">✓ Event deleted.</div>
  )}
  {error && (
    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg">{error}</div>
  )}

  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Event list -->
    <div>
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-semibold text-navy">All Events ({events.length})</h3>
        <a href="/admin/events?new=1" class="btn-primary text-xs px-5 py-2">+ New Event</a>
      </div>

      {events.length > 0 ? (
        <div class="space-y-3">
          {(events as any[]).map(event => (
            <div class="admin-card p-4 flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${
                    event.status === 'upcoming' ? 'bg-forest/10 text-forest' :
                    event.status === 'ongoing' ? 'bg-gold/20 text-gold-700' :
                    'bg-gray-100 text-gray-400'
                  }`}>{event.status}</span>
                  {event.is_featured && <span class="text-xs bg-navy/10 text-navy px-2 py-0.5 rounded-full">Featured</span>}
                </div>
                <p class="font-medium text-navy text-sm truncate">{event.title}</p>
                <p class="text-xs text-gray-400 mt-0.5">{formatDate(event.date)}{event.location ? ` · ${event.location}` : ''}</p>
              </div>
              <div class="flex gap-2 shrink-0">
                <a
                  href={`/admin/events?edit=${event.id}`}
                  class="text-xs text-navy/60 hover:text-navy font-medium transition-colors px-2 py-1 rounded"
                >
                  Edit
                </a>
                <form method="POST">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={event.id} />
                  <button
                    type="submit"
                    class="text-xs text-red-400 hover:text-red-600 font-medium transition-colors px-2 py-1 rounded"
                    onclick="return confirm('Delete this event?')"
                  >
                    Delete
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400 admin-card">
          <p class="mb-3">No events yet.</p>
          <a href="/admin/events?new=1" class="text-gold font-medium hover:underline text-sm">Add your first event →</a>
        </div>
      )}
    </div>

    <!-- Form -->
    {(showNew || editEvent) && (
      <div>
        <h3 class="font-semibold text-navy mb-5">
          {editEvent ? `Editing: ${editEvent.title}` : 'New Event'}
        </h3>
        <form method="POST" class="admin-card p-6 space-y-5">
          <input type="hidden" name="_action" value="upsert" />
          {editEvent && <input type="hidden" name="id" value={editEvent.id} />}

          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Title *</label>
            <input type="text" name="title" required value={editEvent?.title ?? ''} class="input-field" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Description</label>
            <textarea name="description" rows="4" class="input-field resize-none">{editEvent?.description ?? ''}</textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-navy mb-1.5">Date & Time *</label>
              <input
                type="datetime-local"
                name="date"
                required
                value={editEvent ? toDatetimeLocal(editEvent.date) : ''}
                class="input-field"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-navy mb-1.5">Status</label>
              <select name="status" class="input-field">
                {['upcoming', 'ongoing', 'past'].map(s => (
                  <option value={s} selected={editEvent?.status === s}>{s.charAt(0).toUpperCase() + s.slice(1)}</option>
                ))}
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Location</label>
            <input type="text" name="location" value={editEvent?.location ?? ''} class="input-field" placeholder="Lagos, Nigeria" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Image URL</label>
            <input type="url" name="image_url" value={editEvent?.image_url ?? ''} class="input-field" placeholder="https://..." />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy mb-1.5">Registration URL</label>
            <input type="url" name="registration_url" value={editEvent?.registration_url ?? ''} class="input-field" placeholder="https://..." />
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" name="is_featured" id="is_featured" checked={editEvent?.is_featured} class="rounded border-gray-300 text-navy" />
            <label for="is_featured" class="text-sm font-medium text-navy">Feature this event on homepage</label>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary flex-1">
              {editEvent ? 'Save Changes' : 'Create Event'}
            </button>
            <a href="/admin/events" class="flex-1 text-center border border-warm-200 text-navy/60 rounded-full py-3 text-sm font-medium hover:border-navy hover:text-navy transition-colors">
              Cancel
            </a>
          </div>
        </form>
      </div>
    )}

    {!showNew && !editEvent && (
      <div class="hidden lg:flex items-center justify-center text-gray-300 bg-warm-50 rounded-2xl border-2 border-dashed border-warm-200">
        <div class="text-center">
          <div class="text-4xl mb-3">📅</div>
          <p class="text-sm font-medium">Select an event to edit<br/>or create a new one</p>
        </div>
      </div>
    )}
  </div>
</AdminLayout>
